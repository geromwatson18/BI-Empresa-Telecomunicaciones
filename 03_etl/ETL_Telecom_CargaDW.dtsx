              version="7">
              <properties>
                <property
                  dataType="System.Int32"
                  description="The number of seconds before a command times out.  A value of 0 indicates an infinite time-out."
                  name="CommandTimeout">0</property>
                <property
                  dataType="System.String"
                  description="Specifies the name of the database object used to open a rowset."
                  name="OpenRowset"></property>
                <property
                  dataType="System.String"
                  description="Specifies the variable that contains the name of the database object used to open a rowset."
                  name="OpenRowsetVariable"></property>
                <property
                  dataType="System.String"
                  description="The SQL command to be executed."
                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor">SELECT
    c.id_cliente,
    c.codigo_cliente,
    c.tipo_cliente,
    c.edad,
    CASE
        WHEN c.edad BETWEEN 18 AND 25 THEN '18-25'
        WHEN c.edad BETWEEN 26 AND 35 THEN '26-35'
        WHEN c.edad BETWEEN 36 AND 50 THEN '36-50'
        ELSE '51+'
    END AS rango_edad,
    c.sexo,
    c.perfil_consumo,
    c.fecha_registro,
    c.estado AS estado_cliente,
    DATEDIFF(MONTH, COALESCE(cb.fecha_inicio_cliente, c.fecha_registro), GETDATE()) AS antiguedad_meses,
    CASE
        WHEN DATEDIFF(MONTH, COALESCE(cb.fecha_inicio_cliente, c.fecha_registro), GETDATE()) &lt;= 6 THEN 'Nuevo (0-6)'
        WHEN DATEDIFF(MONTH, COALESCE(cb.fecha_inicio_cliente, c.fecha_registro), GETDATE()) &lt;= 24 THEN 'Medio (7-24)'
        ELSE 'Antiguo (25+)'
    END AS segmento_antiguedad
FROM telecom_operacional.dbo.cliente c
LEFT JOIN (
    SELECT
        id_cliente,
        MIN(fecha_inicio) AS fecha_inicio_cliente
    FROM telecom_operacional.dbo.contrato
    GROUP BY id_cliente
) cb
    ON c.id_cliente = cb.id_cliente;</property>
